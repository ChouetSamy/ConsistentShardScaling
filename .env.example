# Configuration du système de Sharding

# ========== CREDENTIALS BASE DE DONNÉES ==========
# Utilisé pour tous les shards (recommandé d'avoir un user dédié par shard en prod)

DB_USER=app_user
DB_PASSWORD=secure_password_here

# ========== SHARD 1 ==========
SHARD_1_HOST=db1.internal.example.com
SHARD_1_PORT=5432
SHARD_1_DBNAME=sharding_db_v1

# ========== SHARD 2 ==========
SHARD_2_HOST=db2.internal.example.com
SHARD_2_PORT=5432
SHARD_2_DBNAME=sharding_db_v1

# ========== SHARD 3 ==========
SHARD_3_HOST=db3.internal.example.com
SHARD_3_PORT=5432
SHARD_3_DBNAME=sharding_db_v1

# ========== SHARD 4 (optionnel, pour migration) ==========
SHARD_4_HOST=db4.internal.example.com
SHARD_4_PORT=5432
SHARD_4_DBNAME=sharding_db_v2

# ========== LOGGING ==========
LOG_CHANNEL=stack
LOG_LEVEL=debug  # debug, info, warning, error (debug pour développement)
